# Neon Postgres (from Neon dashboard)
DATABASE_URL=postgresql://...

# JWT secret for API auth (Next.js will issue JWTs signed with same secret)
JWT_SECRET=your-secret-at-least-32-chars

# Optional: CORS origin (defaults to *)
# CORS_ORIGIN=https://your-app.vercel.app

# Optional: for seed script - email to grant ADMIN role
# ADMIN_EMAIL=admin@example.com

# Gemini API key for AI book enrichment (POST /api/ai/enrich-book). If unset, stub response is returned.
# GEMINI_API_KEY=your-gemini-api-key
# Optional: model id if default fails (e.g. gemini-1.5-flash-latest, gemini-1.5-pro-latest, gemini-2.0-flash)
# GEMINI_MODEL=gemini-1.5-flash-latest

# Google OAuth (Sign in with Google)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
