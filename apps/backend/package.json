{
  "name": "aspire-backend",
  "version": "1.0.0",
  "description": "Express.js backend API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate --schema=../../packages/db/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env -- prisma migrate deploy --schema=../../packages/db/prisma/schema.prisma",
    "db:migrate:dev": "dotenv -e .env -- prisma migrate dev --schema=../../packages/db/prisma/schema.prisma",
    "db:seed": "dotenv -e .env -- tsx ../../packages/db/prisma/seed.ts",
    "test:token": "dotenv -e .env -- tsx scripts/test-token.ts"
  },
  "dependencies": {
    "@aspire/db": "*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "google-auth-library": "^10.6.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.0.0"
  }
}
